# =========================================================
# 11. SPATIAL PLOTS
# =========================================================

def spatial_plot(col, title, fname):
    fig, axes = plt.subplots(1, len(genotypes), figsize=(15, 4))

    for ax, g in zip(axes, genotypes):

        sub = data[data["genotype"] == g].copy()

        x = sub["center_x_cells"].values
        y = sub["center_y_cells"].values

        x = x - np.mean(x)
        y = y - np.mean(y)

        coords = np.vstack((x, y)).T
        scale = np.sqrt((coords**2).sum(axis=1)).mean()

        x = x / scale
        y = y / scale

        v = sub[col].values
        v = v[np.isfinite(v)]

        vmin, vmax = np.percentile(v, [5, 95])

        sc = ax.scatter(
            x, y,
            c=sub[col],
            cmap="viridis",
            s=4,
            vmin=vmin,
            vmax=vmax
        )

        ax.set_title(g)
        ax.set_aspect("equal")
        ax.axis("off")
        plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)

    fig.suptitle(title)
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, fname), dpi=300)
    plt.close()

spatial_plot("area_um2", "Cell area spatial map", "spatial_area.png")
spatial_plot("S1", "Cell elongation spatial map", "spatial_elongation.png")
spatial_plot("neighbour", "Cell neighbour spatial map", "spatial_neighbour.png")


plot_hist("area_um2", area_bins, "Cell area (µm²)", "area_hist.png")
plot_hist("S1", elong_bins, "Cell elongation (S1)", "elongation_hist.png")
plot_hist("neighbour", neigh_bins, "Neighbour", "neighbour_hist.png")

# =========================================================
# 9. AREA VIOLIN (LOG10 + TRIMMED)
# =========================================================

def violin_plot_area(data, out_dir):
    plt.figure(figsize=(6, 4))

    all_vals = data["area_um2"].values
    all_vals = all_vals[all_vals > 0]
    log_all = np.log10(all_vals)

    low, high = np.percentile(log_all, [0.25, 99.75])

    plot_df = []

    for g in genotypes.keys():
        vals = data[data["genotype"] == g]["area_um2"].values
        vals = vals[vals > 0]

        log_vals = np.log10(vals)
        log_vals = log_vals[(log_vals >= low) & (log_vals <= high)]

        plot_df.append(pd.DataFrame({
            "genotype": g,
            "log_area": log_vals
        }))

    plot_df = pd.concat(plot_df, ignore_index=True)

    sns.violinplot(
        data=plot_df,
        x="genotype",
        y="log_area",
        inner="box",
        cut=0,
        scale="width"
    )

    plt.ylabel("Log10 Cell area (µm²)")
    plt.xlabel("")
    plt.title("Cell Area Distribution")
    plt.xticks(rotation=20)

    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, "area_violin.png"), dpi=300)
    plt.close()


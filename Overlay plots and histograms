        r"Rok3Proj-1\TA.db",
    ],
    "Rho1GAP19D RNAi": [
        r"RhoGAP1Proj-1\TA.db",
        r"RhoGAP2Proj-1\TA.db",
        r"RhoGAP3Proj-1\TA.db",
        r"RhoGAP4Proj-1\TA.db",
        r"RhoGAP5Proj-1\TA.db",
        r"RhoGAP6Proj-1\TA.db",
        r"RhoGAP7Proj-1\TA.db",
    ],
}

PIXELS_PER_MICRON = 5.4555   # SET TO SAME SCALE AS IMAGEJ
PX2_TO_UM2 = (1 / PIXELS_PER_MICRON) ** 2

desktop = os.path.join(os.path.expanduser("~"), "Desktop")
out_dir = os.path.join(desktop, "wing_disc_outputs")
os.makedirs(out_dir, exist_ok=True)

colors = {
    "WT": "#1f77b4",
    "Rok RNAi": "#d62728",
    "Rho1GAP19D RNAi": "#2ca02c"
}

# =========================================================
# 2. LOAD DATA
# =========================================================

def load_db(path, genotype, disc_id):
    conn = sqlite3.connect(path)
    df = pd.read_sql_query("SELECT * FROM Cells", conn)
    conn.close()

    df["genotype"] = genotype
    df["disc_id"] = disc_id
    return df


all_data = []

for g, paths in genotypes.items():
    for i, p in enumerate(paths):
        full_path = os.path.join(base_dir, p)
        df = load_db(full_path, g, f"{g}_{i+1}")
        all_data.append(df)

data = pd.concat(all_data, ignore_index=True)
print("Total cells:", len(data))

# =========================================================
# 3. CLEAN + CONVERT
# =========================================================

data["area_um2"] = pd.to_numeric(data["area_cells"], errors="coerce") * PX2_TO_UM2
data["S1"] = pd.to_numeric(data["S1_stretch_cells"], errors="coerce")
data["neighbour"] = pd.to_numeric(data["nb_of_vertices_cut_off"], errors="coerce")

data = data.dropna(subset=["area_um2", "S1", "neighbour", "center_x_cells", "center_y_cells"])

# =========================================================
# 4. EXPORT RAW DATA
# =========================================================

for g in genotypes:
    data[data["genotype"] == g].to_csv(
        os.path.join(out_dir, f"{g}_cells.csv"),
        index=False
    )

# =========================================================
# 5. BINNING
# =========================================================

area_bins = np.linspace(0, data["area_um2"].max(), 50)
elong_bins = np.linspace(data["S1"].min(), data["S1"].max(), 50)
neigh_bins = np.arange(3, 11, 1)

# =========================================================
# 6. AREA HISTOGRAM (LOG10 + 0.25–99.75%)
# =========================================================

plt.figure(figsize=(6, 4))

all_vals = data["area_um2"].values
all_vals = all_vals[all_vals > 0]
log_all = np.log10(all_vals)

low, high = np.percentile(log_all, [0.25, 99.75])

for g in genotypes.keys():
    subset = data[data["genotype"] == g]

    vals = subset["area_um2"].values
    vals = vals[vals > 0]

    log_vals = np.log10(vals)
    log_vals = log_vals[(log_vals >= low) & (log_vals <= high)]

    plt.hist(
        log_vals,
        bins=45,
        density=True,
        histtype='step',
        linewidth=2,
        color=colors[g],
        label=g
    )

plt.xlabel("Log10 Cell area (µm²)")
plt.ylabel("Density")
plt.title(
    "Cell Area Distribution (log10)\n"
    f"Range: {low:.2f} – {high:.2f} (0.25–99.75 percentile)"
)
plt.legend()

plt.tight_layout()
plt.savefig(os.path.join(out_dir, "area_hist_log.png"), dpi=300)
plt.close()

# =========================================================
# 7. HISTOGRAM TABLE EXPORT
# =========================================================

def export_hist_table(col, bins, name):
    rows = []

    for g in genotypes:
        vals = data[data["genotype"] == g][col].values
        vals = vals[np.isfinite(vals)]

        counts, edges = np.histogram(vals, bins=bins, density=True)

        for i in range(len(counts)):
            rows.append([g, edges[i], edges[i+1], counts[i]])

    df_out = pd.DataFrame(rows,
                          columns=["genotype", "bin_start", "bin_end", "density"])

    df_out.to_csv(os.path.join(out_dir, f"{name}_hist_table.csv"), index=False)


export_hist_table("area_um2", area_bins, "area")
export_hist_table("S1", elong_bins, "elongation")
export_hist_table("neighbour", neigh_bins, "neighbour")


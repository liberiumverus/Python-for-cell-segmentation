# =========================================================
# 1. USER SETTINGS
# =========================================================

base_dir = r"D:\Wing_disc_data\Wing_disc_pouch\raw data"


# CHANGE FILE DIRECTORY AS NEEDED -> r"  "  
genotypes = {
    "WT": [
        r"WT1Proj-1\TA.db",
        r"WT2Proj-1\TA.db",
        r"WT3Proj-1\TA.db",
        r"WT4Proj-1\TA.db",
        r"WT5Proj-1\TA.db",
    ],
    "Rok RNAi": [
        r"Rok1Proj-1\TA.db",
